{
  "name": "nova-studio",
  "version": "1.0.0",
  "description": "Nova Studio: lokaal digitaal atelier voor interieuradvies.",
  "main": "server/src/index.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "nodemon server/src/index.js",
    "dev:web": "vite --host 0.0.0.0",
    "start": "node server/src/index.js",
    "seed": "node server/src/seed.js",
    "backup": "node server/src/backup.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "node --test server/src/**/*.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "dayjs": "^1.11.21",
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "multer": "^2.1.1",
    "nanoid": "^5.1.11",
    "pdfkit": "^0.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.0.16"
  }
}
